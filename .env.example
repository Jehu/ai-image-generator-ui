# Kopiere diese Datei nach .env und trage die Werte ein.

# Lokale SQLite-Datei (kein DB-Server nötig)
DATABASE_URL="file:./prisma/data/dev.db"

# Google Gemini API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""

# OpenAI API Key (https://platform.openai.com/api-keys) — optional.
# Wenn gesetzt, stehen OpenAI-Bildmodelle (gpt-image-1, gpt-image-2) zusätzlich
# zur Auswahl; sind beide Keys gesetzt, kann das Modell pro Generierung gewählt werden.
OPENAI_API_KEY=""

# OpenRouter API Key (https://openrouter.ai/keys) — optional.
# Wenn gesetzt, stehen kuratierte Bildmodelle über OpenRouter zur Auswahl
# (Nano Banana Pro / 2 / 1 = Gemini 3 Pro / 3.1 Flash / 2.5 Flash Image,
# GPT-5 Image, GPT-5 Image Mini) — ein einziger Key statt Vendor-Keys je Anbieter.
OPENROUTER_API_KEY=""

# Optionale Attribution-Header für OpenRouter (erscheinen in deren Dashboard).
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_TITLE=""

# Modell für "Stil aus Bild ableiten" (Vision-Analyse, nicht Bildgenerierung).
# Optional — Default: gemini-2.5-flash. Für höhere Analyse-Qualität z.B.
# gemini-2.5-pro setzen.
GEMINI_ANALYSIS_MODEL=""

# Modell für den Markdown-Style-Brief (Text-Prosa aus dem Stil-JSON, nicht
# Bildgenerierung). Optional — Default: gemini-2.5-flash.
GEMINI_BRIEF_MODEL=""
